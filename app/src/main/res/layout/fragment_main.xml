<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/mt_background">

    <ImageView
        android:id="@+id/wallpaperBackground"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:contentDescription="@null"
        android:scaleType="centerCrop"
        android:visibility="gone"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent" />

    <View
        android:id="@+id/wallpaperMask"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:visibility="gone"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent" />

    <LinearLayout
        android:id="@+id/topBar"
        android:layout_width="0dp"
        android:layout_height="56dp"
        android:background="@color/mt_surface"
        android:elevation="4dp"
        android:gravity="center_vertical"
        android:orientation="horizontal"
        android:paddingHorizontal="16dp"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent">

        <ImageView
            android:id="@+id/ivMenu"
            android:layout_width="26dp"
            android:layout_height="26dp"
            android:contentDescription="菜单"
            android:src="@drawable/ic_menu" />

        <FrameLayout
            android:id="@+id/titleSwitcher"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:clipChildren="true"
            android:clipToPadding="true">

            <LinearLayout
                android:id="@+id/desktopTitleGroup"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:alpha="0"
                android:gravity="center"
                android:orientation="vertical">

                <TextView
                    android:id="@+id/tvDesktopTitle"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="馒头桌面"
                    android:textColor="@color/mt_text_primary"
                    android:textSize="16sp"
                    android:textStyle="bold" />
            </LinearLayout>

            <LinearLayout
                android:id="@+id/chatTitleGroup"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:gravity="center"
                android:orientation="vertical">

                <TextView
                    android:id="@+id/tvChatTitle"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="馒头"
                    android:textColor="@color/mt_text_primary"
                    android:textSize="16sp"
                    android:textStyle="bold" />

                <TextView
                    android:id="@+id/tvChatSubtitle"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="请配置你的模型"
                    android:textColor="@color/mt_text_muted"
                    android:textSize="12sp" />
            </LinearLayout>

            <LinearLayout
                android:id="@+id/workspaceTitleGroup"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:alpha="0"
                android:gravity="center"
                android:orientation="vertical">

                <TextView
                    android:id="@+id/tvWorkspaceTitle"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="文件架构"
                    android:textColor="@color/mt_text_primary"
                    android:textSize="16sp"
                    android:textStyle="bold" />

                <TextView
                    android:id="@+id/tvWorkspaceSubtitle"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="agent | memory | webapp"
                    android:textColor="@color/mt_text_secondary"
                    android:textSize="12sp" />
            </LinearLayout>
        </FrameLayout>

        <ImageView
            android:id="@+id/newChat"
            android:layout_width="26dp"
            android:layout_height="26dp"
            android:contentDescription="新建会话"
            android:src="@drawable/ic_topic" />
    </LinearLayout>

    <androidx.viewpager2.widget.ViewPager2
        android:id="@+id/mainPager"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:background="@color/mt_background"
        android:overScrollMode="never"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/topBar" />

</androidx.constraintlayout.widget.ConstraintLayout>
