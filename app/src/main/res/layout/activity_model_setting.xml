<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="#F5F6F8"
    tools:context=".view.ModelSettingActivity">

    <!-- 顶部 Toolbar -->
    <com.google.android.material.appbar.MaterialToolbar
        android:id="@+id/toolbar"
        android:layout_width="match_parent"
        android:layout_height="38dp"
        android:background="#F5F6F8"
        app:title="模型配置"
        app:titleCentered="true"
        app:titleTextColor="#1F2937"
        app:titleTextAppearance="@style/TextAppearance.Material3.TitleLarge"
        app:navigationIcon="@drawable/ic_arrow_back"
        app:navigationIconTint="#1F2937" />

    <!-- 主要内容 -->
    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:fillViewport="true"
        android:scrollbars="none">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingHorizontal="20dp"
            android:paddingBottom="24dp">

            <!-- ============ Provider 配置区域 ============ -->

            <!-- 标题 + 分割线 -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:gravity="center_vertical"
                android:orientation="horizontal"
                android:layout_marginTop="8dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Provider 配置"
                    android:textColor="#9CA3AF"
                    android:textSize="14sp"
                    android:textStyle="bold" />

                <View
                    android:layout_width="0dp"
                    android:layout_height="1dp"
                    android:layout_marginStart="12dp"
                    android:layout_weight="1"
                    android:background="#E5E7EB" />
            </LinearLayout>

            <!-- 描述文字 -->
            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="10dp"
                android:text="新增、切换并维护模型服务提供商的名称、地址与密钥。"
                android:textColor="#374151"
                android:textSize="14sp" />

            <!-- Provider Tab 行 -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="18dp"
                android:gravity="center_vertical"
                android:orientation="horizontal">

                <!-- 当前 Provider 下拉（占满剩余空间并省略长名称，避免把右侧按钮挤出屏幕） -->
                <com.google.android.material.textfield.TextInputLayout
                    android:id="@+id/tilProvider"
                    style="@style/Widget.Material3.TextInputLayout.OutlinedBox"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:layout_marginEnd="8dp"
                    app:boxBackgroundColor="#FFFFFF"
                    app:boxCornerRadiusBottomEnd="12dp"
                    app:boxCornerRadiusBottomStart="12dp"
                    app:boxCornerRadiusTopEnd="12dp"
                    app:boxCornerRadiusTopStart="12dp"
                    app:boxStrokeColor="#EAECEF"
                    app:boxStrokeWidth="1dp"
                    app:boxStrokeWidthFocused="1dp"
                    app:endIconMode="dropdown_menu"
                    app:endIconTint="#1F2937"
                    app:hintEnabled="false">

                    <AutoCompleteTextView
                        android:id="@+id/actvProvider"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:background="@android:color/transparent"
                        android:clickable="true"
                        android:ellipsize="end"
                        android:focusable="false"
                        android:inputType="none"
                        android:maxLines="1"
                        android:text="Model"
                        android:textColor="#1F2937"
                        android:textSize="14sp"
                        android:textStyle="bold" />
                </com.google.android.material.textfield.TextInputLayout>

                <!-- 第二个 Provider 下拉 -->
                <com.google.android.material.textfield.TextInputLayout
                    android:id="@+id/tilProvider2"
                    style="@style/Widget.Material3.TextInputLayout.OutlinedBox"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    app:boxBackgroundColor="#FFFFFF"
                    app:boxCornerRadiusBottomEnd="12dp"
                    app:boxCornerRadiusBottomStart="12dp"
                    app:boxCornerRadiusTopEnd="12dp"
                    app:boxCornerRadiusTopStart="12dp"
                    app:boxStrokeColor="#EAECEF"
                    app:boxStrokeWidth="1dp"
                    app:boxStrokeWidthFocused="1dp"
                    app:endIconMode="dropdown_menu"
                    app:endIconTint="#1F2937"
                    app:hintEnabled="false">

                    <AutoCompleteTextView
                        android:id="@+id/actvProvider2"
                        android:layout_width="110dp"
                        android:layout_height="wrap_content"
                        android:background="@android:color/transparent"
                        android:clickable="true"
                        android:focusable="false"
                        android:inputType="none"
                        android:text="OpenAI"
                        android:textColor="#1F2937"
                        android:textSize="14sp"
                        android:textStyle="bold" />
                </com.google.android.material.textfield.TextInputLayout>

                <!-- 删除按钮 -->
                <ImageView
                    android:id="@+id/btnDeleteProvider"
                    android:layout_width="36dp"
                    android:layout_height="36dp"
                    android:background="@drawable/bg_card_white_rounded"
                    android:contentDescription="删除"
                    android:padding="12dp"
                    android:src="@drawable/ic_delete_outline" />

                <!-- 新增按钮 -->
                <ImageView
                    android:id="@+id/btnAddProvider"
                    android:layout_width="36dp"
                    android:layout_height="36dp"
                    android:layout_marginStart="8dp"
                    android:background="@drawable/bg_card_white_rounded"
                    android:contentDescription="新增"
                    android:padding="12dp"
                    android:src="@drawable/ic_plus" />
            </LinearLayout>

            <!-- Provider 名称 -->
            <com.google.android.material.textfield.TextInputLayout
                style="@style/Widget.Material3.TextInputLayout.OutlinedBox"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp"
                android:hint="Provider 名称"
                app:boxBackgroundColor="#FFFFFF"
                app:boxCornerRadiusBottomEnd="12dp"
                app:boxCornerRadiusBottomStart="12dp"
                app:boxCornerRadiusTopEnd="12dp"
                app:boxCornerRadiusTopStart="12dp"
                app:boxStrokeColor="#EAECEF"
                app:boxStrokeWidth="1dp"
                app:hintTextColor="#9CA3AF">

                <com.google.android.material.textfield.TextInputEditText
                    android:id="@+id/etProviderName"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:inputType="text"
                    android:textColor="#1F2937"
                    android:textSize="16sp" />
            </com.google.android.material.textfield.TextInputLayout>

            <!-- Base URL -->
            <com.google.android.material.textfield.TextInputLayout
                style="@style/Widget.Material3.TextInputLayout.OutlinedBox"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:hint="Base URL"
                app:boxBackgroundColor="#FFFFFF"
                app:boxCornerRadiusBottomEnd="12dp"
                app:boxCornerRadiusBottomStart="12dp"
                app:boxCornerRadiusTopEnd="12dp"
                app:boxCornerRadiusTopStart="12dp"
                app:boxStrokeColor="#EAECEF"
                app:boxStrokeWidth="1dp"
                app:hintTextColor="#9CA3AF">

                <com.google.android.material.textfield.TextInputEditText
                    android:id="@+id/etBaseUrl"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:inputType="textUri"
                    android:textColor="#1F2937"
                    android:textColorHint="#9CA3AF"
                    android:textSize="16sp" />
            </com.google.android.material.textfield.TextInputLayout>

            <!-- API Key -->
            <com.google.android.material.textfield.TextInputLayout
                style="@style/Widget.Material3.TextInputLayout.OutlinedBox"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:hint="API Key"
                app:boxBackgroundColor="#FFFFFF"
                app:boxCornerRadiusBottomEnd="12dp"
                app:boxCornerRadiusBottomStart="12dp"
                app:boxCornerRadiusTopEnd="12dp"
                app:boxCornerRadiusTopStart="12dp"
                app:boxStrokeColor="#EAECEF"
                app:boxStrokeWidth="1dp"
                app:endIconMode="password_toggle"
                app:endIconTint="#9CA3AF"
                app:hintTextColor="#9CA3AF">

                <com.google.android.material.textfield.TextInputEditText
                    android:id="@+id/etApiKey"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:inputType="textPassword"
                    android:textColor="#1F2937"
                    android:textColorHint="#9CA3AF"
                    android:textSize="16sp" />
            </com.google.android.material.textfield.TextInputLayout>

            <!-- API Key 辅助文字 -->
            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:text="未填写 API Key 时，会以无鉴权方式请求 Provider。"
                android:textColor="#9CA3AF"
                android:textSize="13sp" />

            <!-- ============ 模型列表区域 ============ -->

            <!-- 标题 + 分割线 -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="28dp"
                android:gravity="center_vertical"
                android:orientation="horizontal">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="模型列表"
                    android:textColor="#9CA3AF"
                    android:textSize="14sp"
                    android:textStyle="bold" />

                <View
                    android:layout_width="0dp"
                    android:layout_height="1dp"
                    android:layout_marginStart="12dp"
                    android:layout_weight="1"
                    android:background="#E5E7EB" />
            </LinearLayout>

            <!-- 描述文字 -->
            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="10dp"
                android:text="支持手动补充模型，也可从当前 Provider 拉取远端模型清单。"
                android:textColor="#374151"
                android:textSize="14sp" />

            <!-- 操作行：计数 + 添加 + 下载 + 排序 -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="18dp"
                android:gravity="center_vertical"
                android:orientation="horizontal">

                <TextView
                    android:id="@+id/tvModelCount"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="共 0 个模型"
                    android:textColor="#374151"
                    android:textSize="15sp"
                    android:textStyle="bold" />

                <Space
                    android:layout_width="0dp"
                    android:layout_height="0dp"
                    android:layout_weight="1" />

                <!-- 添加模型 -->
                <ImageView
                    android:id="@+id/btnAddModel"
                    android:layout_width="36dp"
                    android:layout_height="36dp"
                    android:background="@drawable/bg_card_white_rounded"
                    android:contentDescription="添加模型"
                    android:padding="12dp"
                    android:src="@drawable/ic_plus" />

                <!-- 拉取远端模型 (蓝色) -->
                <ImageView
                    android:id="@+id/btnRefreshModels"
                    android:layout_width="36dp"
                    android:layout_height="36dp"
                    android:layout_marginStart="10dp"
                    android:background="@drawable/bg_blue_rounded"
                    android:contentDescription="拉取远端模型"
                    android:padding="12dp"
                    android:src="@drawable/ic_download" />

                <!-- 排序 -->
                <ImageView
                    android:id="@+id/btnSortModels"
                    android:layout_width="36dp"
                    android:layout_height="36dp"
                    android:layout_marginStart="8dp"
                    android:background="@android:color/transparent"
                    android:contentDescription="排序"
                    android:padding="8dp"
                    android:src="@drawable/ic_sort_list" />
            </LinearLayout>

            <!-- 模型列表 RecyclerView -->
            <androidx.recyclerview.widget.RecyclerView
                android:id="@+id/rvModelList"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:nestedScrollingEnabled="false" />

            <!-- 空状态 -->
            <LinearLayout
                android:id="@+id/emptyModelState"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="64dp"
                android:gravity="center"
                android:orientation="vertical">

                <ImageView
                    android:layout_width="72dp"
                    android:layout_height="72dp"
                    android:contentDescription="@null"
                    android:src="@drawable/ic_package_empty" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="14dp"
                    android:text="请添加模型！"
                    android:textColor="#6B7280"
                    android:textSize="15sp"
                    android:textStyle="bold" />
            </LinearLayout>

        </LinearLayout>
    </ScrollView>
</LinearLayout>
