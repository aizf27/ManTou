<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:background="@color/mt_background"
    android:orientation="vertical">

    <LinearLayout
        android:id="@+id/headerRow"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:clickable="true"
        android:focusable="true"
        android:foreground="?attr/selectableItemBackground"
        android:gravity="center_vertical"
        android:orientation="horizontal"
        android:paddingTop="14dp"
        android:paddingBottom="14dp">

        <View
            android:id="@+id/dot"
            android:layout_width="10dp"
            android:layout_height="10dp"
            android:layout_marginEnd="14dp"
            android:background="@drawable/bg_dot_success" />

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical">

            <TextView
                android:id="@+id/tvModel"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:ellipsize="end"
                android:maxLines="1"
                android:text="model"
                android:textColor="@color/mt_text_primary"
                android:textSize="16sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/tvEndpoint"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="2dp"
                android:ellipsize="end"
                android:maxLines="1"
                android:text="endpoint"
                android:textColor="@color/mt_text_muted"
                android:textSize="12sp" />

            <TextView
                android:id="@+id/tvTime"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="6dp"
                android:text="2026-01-01 00:00:00"
                android:textColor="@color/mt_text_secondary"
                android:textSize="13sp" />

            <TextView
                android:id="@+id/tvTags"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="6dp"
                android:text="OpenAI · 流式 · HTTP 200"
                android:textColor="#27AE60"
                android:textSize="13sp" />
        </LinearLayout>

        <ImageView
            android:id="@+id/ivExpand"
            android:layout_width="18dp"
            android:layout_height="18dp"
            android:src="@drawable/ic_chevron_down"
            app:tint="@color/mt_text_muted"
            xmlns:app="http://schemas.android.com/apk/res-auto" />
    </LinearLayout>

    <LinearLayout
        android:id="@+id/detailBox"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginBottom="10dp"
        android:background="@color/mt_surface_soft"
        android:orientation="vertical"
        android:paddingHorizontal="12dp"
        android:paddingVertical="10dp"
        android:visibility="gone">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="请求"
            android:textColor="@color/mt_text_muted"
            android:textSize="11sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/tvRequestBody"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            android:fontFamily="monospace"
            android:text=""
            android:textColor="@color/mt_code_text"
            android:textIsSelectable="true"
            android:textSize="11sp" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="10dp"
            android:text="响应"
            android:textColor="@color/mt_text_muted"
            android:textSize="11sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/tvResponseBody"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            android:fontFamily="monospace"
            android:text=""
            android:textColor="@color/mt_code_text"
            android:textIsSelectable="true"
            android:textSize="11sp" />
    </LinearLayout>

    <View
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:background="@color/mt_outline" />
</LinearLayout>
