<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools">
    <!-- 相机权限（Web App CameraTool 使用） -->
    <uses-permission android:name="android.permission.CAMERA" />
    <uses-feature
        android:name="android.hardware.camera"
        android:required="false" /> <!-- 网络权限 -->
    <uses-permission android:name="android.permission.INTERNET" />
    <uses-permission android:name="android.permission.ACCESS_NETWORK_STATE" />
    <!-- 振动权限 (VibrationTool) -->
    <uses-permission android:name="android.permission.VIBRATE" />
    <uses-permission android:name="android.permission.RECORD_AUDIO" />

    <application
        android:allowBackup="true"
        android:dataExtractionRules="@xml/data_extraction_rules"
        android:fullBackupContent="@xml/backup_rules"
        android:icon="@drawable/mantou"
        android:label="@string/app_name"
        android:roundIcon="@drawable/mantou"
        android:supportsRtl="true"
        android:theme="@style/Theme.ManTou">
        <activity
            android:name=".view.ModelSettingActivity"
            android:exported="false" />
        <activity
            android:name=".view.JsonViewerActivity"
            android:exported="false" />
        <activity
            android:name=".view.WorkspaceMemorySettingsActivity"
            android:exported="false" />
        <activity
            android:name=".view.AppearanceSettingsActivity"
            android:exported="false" />
        <activity
            android:name=".view.RequestLogActivity"
            android:exported="false" />
        <activity
            android:name=".view.SettingsActivity"
            android:exported="false" />
        <activity
            android:name=".view.MainActivity"
            android:exported="true"
            android:windowSoftInputMode="adjustNothing">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />

                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>
        <activity
            android:name=".view.VirtualAppActivity"
            android:exported="true"
            android:theme="@style/Theme.ManTou">
            <intent-filter>
                <action android:name="android.intent.action.VIEW" />

                <category android:name="android.intent.category.DEFAULT" />

                <data
                    android:mimeType="text/html"
                    android:scheme="content" />
                <data
                    android:mimeType="text/html"
                    android:scheme="file" />
                <data
                    android:mimeType="application/octet-stream"
                    android:scheme="content" />
                <data
                    android:mimeType="application/octet-stream"
                    android:scheme="file" />
            </intent-filter>
            <intent-filter>
                <action android:name="android.intent.action.SEND" />

                <category android:name="android.intent.category.DEFAULT" />

                <data android:mimeType="text/html" />
                <data android:mimeType="application/octet-stream" />
            </intent-filter>
        </activity> <!-- FileProvider 用于分享生成的 HTML -->
        <provider
            android:name="androidx.core.content.FileProvider"
            android:authorities="${applicationId}.fileprovider"
            android:exported="false"
            android:grantUriPermissions="true">
            <meta-data
                android:name="android.support.FILE_PROVIDER_PATHS"
                android:resource="@xml/file_paths" />
        </provider>
    </application>

</manifest>
